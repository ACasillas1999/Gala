---
import Layout from '../layouts/Layout.astro';
import UploadForm from '../components/UploadForm';
---
<Layout title="Subir Contenido">
  <div class="upload-card glass-container fade-in">
    <h2>Subir Contenido</h2>
    <UploadForm client:load />
    <a href="/gallery" class="back-link">← Cancelar y volver a la galería</a>
  </div>
</Layout>

<style>
  .upload-card {
    max-width: 500px;
    width: 100%;
    text-align: center;
    padding: 3rem 2rem;
    position: relative;
  }
  .upload-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: linear-gradient(90deg, transparent, var(--primary), transparent);
    border-radius: 20px 20px 0 0;
  }
  h2 {
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }
  .back-link {
    display: inline-block;
    margin-top: 2rem;
    color: #888;
    text-decoration: none;
    font-size: 0.8rem;
    transition: color 0.3s;
  }
  .back-link:hover { color: var(--primary); }

  /* Styles needed by UploadForm.tsx (passed via global) */
  :global(.form-group) { margin-bottom: 2rem; text-align: left; }
  :global(.label-premium) {
    display: block; margin-bottom: 10px; color: var(--primary);
    font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1.5px;
  }
  :global(.input-premium) {
    width: 100%; padding: 15px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--glass-border);
    border-radius: 12px; color: white;
    font-family: 'Outfit', sans-serif; font-size: 1rem;
    transition: all 0.3s; outline: none;
  }
  :global(.input-premium:focus) {
    border-color: var(--primary);
    background: rgba(255,255,255,0.07);
    box-shadow: 0 0 15px rgba(212,175,55,0.1);
  }
  :global(.file-upload-area) {
    width: 100%; height: 180px;
    border: 2px dashed var(--glass-border);
    border-radius: 15px; display: flex;
    flex-direction: column; align-items: center; justify-content: center;
    cursor: pointer; transition: all 0.3s;
    background: rgba(255,255,255,0.01);
  }
  :global(.file-upload-area:hover) {
    border-color: var(--primary);
    background: rgba(212,175,55,0.05);
  }
  :global(.file-upload-area svg) { width: 48px; height: 48px; color: var(--primary); margin-bottom: 15px; opacity: 0.7; }
  :global(.file-upload-area p) { margin: 0; font-size: 0.9rem; opacity: 0.8; }
  :global(.file-hint) { text-align: center; margin-top: 10px; font-size: 0.75rem; opacity: 0.5; }
  :global(.btn-submit) { width: 100%; margin-top: 1rem; padding: 18px; font-size: 1rem; }
  :global(.btn-submit:disabled) { opacity: 0.6; cursor: not-allowed; transform: none; }
  :global(.alert-success) {
    background: rgba(40,167,69,0.1); border: 1px solid rgba(40,167,69,0.3);
    color: #4cd137; padding: 15px; border-radius: 12px; margin-bottom: 2rem;
    font-size: 0.9rem; display: flex; align-items: center; justify-content: center; gap: 10px;
  }
  :global(.alert-error) {
    background: rgba(220,53,69,0.1); border: 1px solid rgba(220,53,69,0.3);
    color: #ff6b7a; padding: 15px; border-radius: 12px; margin-bottom: 2rem; font-size: 0.9rem;
  }
</style>
